# ==============================================================================
# Docker 构建忽略文件
# 作用：排除不必要的文件，减少构建上下文体积，加快构建速度
# ==============================================================================

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.iml

# 环境变量（敏感信息不应该打包进镜像）
.env
.env.*
!.env.example

# 文档
*.md
!README.md
docs/

# 测试
**/test
**/*.test.*
**/*.spec.*

# 构建产物
**/build
**/dist
**/target

# 日志
*.log
logs/

# Gradle
gradle/wrapper/*.jar
!.gradle/wrapper/gradle-wrapper.jar

# Node
node_modules/
.npm
.pnpm-store/

# 前端构建
frontend/dist/
frontend/node_modules/

# Docker
docker/
Dockerfile
docker-compose*.yml
!.dockerignore

# 其他
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
