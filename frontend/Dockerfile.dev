# ==============================================================================
# 前端开发环境 Dockerfile
# 特点：
#   - 支持 Vite HMR（热模块替换）
#   - 挂载源代码到容器内
#   - 开发服务器自动重启
# ==============================================================================

FROM node:20-alpine

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm

# 复制依赖定义文件
COPY package.json pnpm-lock.yaml ./

# 安装依赖
RUN pnpm install

# 复制源代码
COPY . .

# 暴露端口
# 3000: Vite 开发服务器
# 5173: Vite 默认端口
EXPOSE 3000 5173

# 启动命令：开发模式
# --host: 允许外部访问
# --port: 指定端口
CMD ["pnpm", "dev", "--host", "--port", "3000"]
